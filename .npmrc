# @kalibr/sdk declares a peerOptional on @anthropic-ai/sdk@^0.20.0, but the root
# project uses @anthropic-ai/sdk@^0.100.1. Since it's only an optional peer, we
# accept the newer SDK rather than downgrade. This lets a plain `npm install`
# succeed without everyone needing to pass --legacy-peer-deps by hand.
legacy-peer-deps=true

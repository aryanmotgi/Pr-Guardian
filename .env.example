# Copy to .env (gitignored) and fill in. NEVER commit real secrets.

DAYTONA_API_KEY=

# Kalibr — orchestration + self-healing for the Claude fix loop.
# Get from https://dashboard.kalibr.systems → API Keys.
# Leave blank to fall back to direct Anthropic (no routing or self-healing).
KALIBR_API_KEY=
# ASSUMPTION: KALIBR_TENANT_ID is required alongside KALIBR_API_KEY.
#   Shown in Kalibr quickstart env vars. Check dashboard if unsure.
KALIBR_TENANT_ID=
ANTHROPIC_API_KEY=
TIGRIS_ACCESS_KEY_ID=
TIGRIS_SECRET_ACCESS_KEY=
TIGRIS_BUCKET_NAME=

# Insforge — get from your project dashboard or `npx @insforge/cli metadata`
INSFORGE_URL=
INSFORGE_ANON_KEY=

# Slack incoming webhook URL for the merge ping (close-of-loop).
# Create one at https://api.slack.com/apps → Incoming Webhooks.
SLACK_WEBHOOK_URL=

# Set to false to make GitHub/Slack calls for real. Unset/anything-else = dry-run.
DRY_RUN=false

# GitHub auth for the merge + receipt steps (PAT with repo scope).
GITHUB_TOKEN=

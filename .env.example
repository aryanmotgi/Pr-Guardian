# Copy to .env (gitignored) and fill in. NEVER commit real secrets.

# Slack incoming webhook URL for the merge ping (close-of-loop).
# Create one at https://api.slack.com/apps → Incoming Webhooks.
SLACK_WEBHOOK_URL=

# Set to false to make GitHub/Slack calls for real. Unset/anything-else = dry-run.
DRY_RUN=false

# GitHub auth for the merge + receipt steps (PAT with repo scope).
GITHUB_TOKEN=
